    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "dates = []\n",
    "close = []\n",
    "\n",
    "for btc_dict in btc_data:\n",
    "    dates.append(btc_dict['date'])\n",
    "    close.append(int(float(btc_dict['close'])))\n",
    "\n",
    "# 创建图形和坐标轴\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "\n",
    "# 绘制折线图\n",
    "ax.plot(dates, close, linewidth=2, label='Close Price')\n",
    "\n",
    "# 设置标题和轴标签\n",
    "ax.set_title('Close Price RMB', fontsize=16)\n",
    "ax.set_xlabel('Date', fontsize=12)\n",
    "ax.set_ylabel('Price (RMB)', fontsize=12)\n",
    "\n",
    "# 旋转 x 轴标签，避免重叠\n",
    "plt.xticks(rotation=20, ha='right')\n",
    "\n",
    "# 设置主刻度间隔（每隔 N 个日期显示一个标签）\n",
    "N = 20\n",
    "if len(dates) > N:\n",
    "    # 选取间隔索引\n",
    "    major_indices = dates[::N]\n",
    "    ax.set_xticks(major_indices)   # 但日期标签可能过长，建议只显示部分\n",
    "    # 如果想保留全部日期但只显示部分标签，可以：\n",
    "    # ax.set_xticks(dates)  # 全部刻度\n",
    "    # ax.set_xticklabels([d if i % N == 0 else '' for i, d in enumerate(dates)])\n",
    "\n",
    "# 添加网格（可选）\n",
    "ax.grid(True, linestyle='--', alpha=0.6)\n",
    "\n",
    "# 添加图例（如果需要）\n",
    "ax.legend()\n",
    "\n",
    "# 自动调整布局\n",
    "plt.tight_layout()\n",
    "\n",
    "# 保存为文件（支持 PNG, PDF, SVG 等）\n",
    "plt.savefig('The_Line_Chart_of_Close_Price.png', dpi=300)   # 保存为 PNG\n",
    "# 或者保存为 SVG（矢量图）\n",
    "# plt.savefig('The_Line_Chart_of_Close_Price.svg', format='svg')\n",
    "\n",
    "# 如果需要在屏幕上显示\n",
    "plt.show()"
   ]
