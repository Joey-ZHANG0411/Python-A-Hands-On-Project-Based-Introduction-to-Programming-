    "import pygal\n",
    "import math\n",
    "from IPython.display import SVG, display\n",
    "\n",
    "# 假设 dates 和 close 已从 btc_data 中提取\n",
    "# dates = [...], close = [...]\n",
    "\n",
    "line_chart = pygal.Line(\n",
    "    x_label_rotation=30,          # 旋转角度，避免标签重叠\n",
    "    show_minor_x_labels=False,    # 不显示次要标签\n",
    "    width=1000,                   # 图表宽度（像素）\n",
    "    height=500\n",
    ")\n",
    "line_chart.title = '收盘价对数变换'\n",
    "\n",
    "# ===== 关键：x 轴刻度每 20 天显示一个 =====\n",
    "N= 20\n",
    "line_chart.x_labels = dates  # 只显示部分日期作为刻度标签\n",
    "line_chart.x_labels_major=dates[::N]\n",
    "# 计算对数收盘价\n",
    "close_log = [math.log10(value) for value in close]\n",
    "\n",
    "# ===== 添加数据：显示所有点（标记），不显示数值标签 =====\n",
    "line_chart.add('log收盘价', close_log,\n",
    "               show_dots=True,          # 所有点显示\n",
    "               dots_size=3,             # 点的大小\n",
    "               stroke=True)             # 画线\n",
    "\n",
    "# 在 Jupyter 中显示\n",
    "display(SVG(line_chart.render()))\n"
   ]
