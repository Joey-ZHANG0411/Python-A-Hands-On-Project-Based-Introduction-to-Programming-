    "#利用plotly渲染\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "# --- 提取数据 ---\n",
    "dates = []\n",
    "close = []\n",
    "months = []\n",
    "weekdays = []\n",
    "\n",
    "for btc_dict in btc_data:\n",
    "    dates.append(btc_dict['date'])\n",
    "    close.append(int(float(btc_dict['close'])))\n",
    "    months.append(int(btc_dict['month']))\n",
    "    weekdays.append(btc_dict['weekday'])\n",
    "\n",
    "# --- 创建图表 ---\n",
    "fig = go.Figure()\n",
    "\n",
    "fig.add_trace(go.Scatter(\n",
    "    x=dates,\n",
    "    y=close,\n",
    "    mode='lines+markers',\n",
    "    name='收盘价',\n",
    "    line=dict(width=2, color='#1f77b4'),\n",
    "    marker=dict(size=8, color='#1f77b4'),\n",
    "    \n",
    "    customdata=list(zip(months, weekdays)),\n",
    "    \n",
    "    hovertemplate=(\n",
    "        '<b>日期</b>: %{x}<br>'\n",
    "        '<b>收盘价</b>: %{y} RMB<br>'\n",
    "        '<b>月份</b>: %{customdata[0]}<br>'\n",
    "        '<b>星期</b>: %{customdata[1]}<extra></extra>'\n",
    "    ),\n",
    "    \n",
    "))\n",
    "\n",
    "# --- 布局调整 ---\n",
    "fig.update_layout(\n",
    "    title='交易收盘价（人民币）',\n",
    "    xaxis_title='日期',\n",
    "    yaxis_title='价格 (RMB)',\n",
    "    xaxis=dict(tickangle=20),\n",
    "    hovermode='x unified',   # 统一悬停模式（显示一条垂直线和所有点）\n",
    "    template='plotly_white', # 美观的背景\n",
    ")\n",
    "\n",
    "# --- 显示和保存 ---\n",
    "fig.show()\n",
    "fig.write_html('btc_close_price.html')"
   ]
